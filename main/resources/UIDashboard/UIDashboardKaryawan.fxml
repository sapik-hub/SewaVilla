<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ProjekAstra.Controller.Dashboard.DashboardKaryawan"
            style="-fx-background-color: #F1F5F9;">

    <left>
        <VBox prefWidth="220" spacing="5" style="-fx-background-color: #1565C0;">
            <padding><Insets top="20" bottom="20" left="15" right="15"/></padding>

            <Label text="VillaStay" textFill="white">
                <font><Font name="System Bold" size="22"/></font>
            </Label>
            <Label text="Villa Rental Management" textFill="#BBDEFB" style="-fx-font-size: 11px;"/>

            <Region prefHeight="25"/>

            <Button fx:id="btnKaryawan" text="👤  Karyawan" onAction="#handleKaryawan"
                    prefWidth="190" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: white; -fx-text-fill: #1565C0; -fx-background-radius: 8; -fx-font-weight: bold;"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="25" right="25"/></padding>

            <Label fx:id="lblJudul" text="Dashboard">
                <font><Font name="System Bold" size="18"/></font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Keluar" onAction="#handleLogout" prefHeight="35" prefWidth="90"
                    style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentPane">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="Selamat datang di Dashboard VillaStay" style="-fx-text-fill: #616161; -fx-font-size: 14px;"/>
        </StackPane>
    </center>

</BorderPane>