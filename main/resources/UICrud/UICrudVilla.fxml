<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ProjekAstra.Controller.Master.CrudVilla">

    <center>
        <HBox spacing="15">
            <padding><Insets top="0" bottom="15" left="0" right="0"/></padding>

            <VBox spacing="12" prefWidth="280" style="-fx-background-color: white; -fx-background-radius: 12;">
                <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

                <Label text="Form Villa">
                    <font><Font name="System Bold" size="15"/></font>
                </Label>

                <TextField fx:id="txtId" promptText="ID Villa" editable="false" style="-fx-background-color: #F1F5F9;"/>
                <ComboBox fx:id="cbPemilik" promptText="Pilih Pemilik" maxWidth="Infinity"/>
                <ComboBox fx:id="cbKategori" promptText="Pilih Kategori" maxWidth="Infinity"/>
                <TextField fx:id="txtNamaVilla" promptText="Nama Villa"/>
                <TextField fx:id="txtKapasitas" promptText="Kapasitas (orang)"/>
                <TextField fx:id="txtHarga" promptText="Harga per malam"/>
                <TextField fx:id="txtAlamat" promptText="Alamat Villa"/>
                <ComboBox fx:id="cbStatus" promptText="Status" maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>
                <TextField fx:id="txtCari" promptText="Cari villa..."/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12;">
                <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

                <TableView fx:id="tableVilla" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID Villa" prefWidth="90"/>
                        <TableColumn fx:id="colPemilik" text="Pemilik" prefWidth="130"/>
                        <TableColumn fx:id="colKategori" text="Kategori" prefWidth="110"/>
                        <TableColumn fx:id="colNamaVilla" text="Nama Villa" prefWidth="150"/>
                        <TableColumn fx:id="colKapasitas" text="Kapasitas" prefWidth="80"/>
                        <TableColumn fx:id="colHarga" text="Harga" prefWidth="100"/>
                        <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="160"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 12;">
            <padding><Insets top="15" bottom="15" left="20" right="20"/></padding>

            <Button fx:id="btnSimpan" text="Simpan" onAction="#handleSimpan"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="100"/>
            <Button fx:id="btnUbah" text="Ubah" onAction="#handleUbah"
                    style="-fx-background-color: #FB8C00; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="100"/>
            <Button fx:id="btnHapus" text="Hapus" onAction="#handleHapus"
                    style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="100"/>
            <Button text="Reset" onAction="#handleReset"
                    style="-fx-background-color: #ECEFF1; -fx-text-fill: #424242; -fx-font-weight: bold;" prefWidth="100"/>
        </HBox>
    </bottom>

</BorderPane>